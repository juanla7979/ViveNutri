<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/background_dark">

    <androidx.cardview.widget.CardView
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_marginBottom="32dp"
        app:cardCornerRadius="50dp"
        app:cardElevation="0dp"
        android:layout_gravity="center">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:contentDescription="Logo"/>

    </androidx.cardview.widget.CardView>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ViveNutri"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_dark"
        android:gravity="center"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Conoce que tan saludable es tu dieta\n al responder nuestra encuesta"
        android:textSize="14sp"
        android:textColor="@color/text_secondary_dark"
        android:gravity="center"
        android:layout_marginBottom="48dp"/>

    <Button
        android:id="@+id/btnNuevaEncuesta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Realizar Encuesta"
        android:textSize="16sp"
        android:textColor="@color/background_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/success_dark"/>

    <Button
        android:id="@+id/btnVerHistorial"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Historial de Encuestas"
        android:textSize="16sp"
        android:textColor="@color/background_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/info_dark"/>

    <Button
        android:id="@+id/btnEditarDatos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mis Datos"
        android:textSize="16sp"
        android:textColor="@color/background_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/primary_dark"/>

    <Button
        android:id="@+id/btnImportar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Importar datos desde csv"
        android:textSize="16sp"
        android:textColor="@color/background_dark"
        android:padding="14dp"
        android:layout_marginBottom="12dp"
        android:backgroundTint="@color/warning_dark"/>

    <Button
        android:id="@+id/btnSalir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salir"
        android:textSize="16sp"
        android:textColor="@color/text_primary_dark"
        android:padding="14dp"
        android:backgroundTint="@color/error_dark"/>

</LinearLayout>