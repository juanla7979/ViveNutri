<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_dark">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/surface_light"
        android:elevation="4dp"
        app:title="Historial de Encuestas"
        app:titleTextColor="@color/text_primary_dark"
        app:titleTextAppearance="@style/TextAppearance.AppCompat.Widget.ActionBar.Title"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="\n\nAquí puedes ver todas las encuestas que has realizado. Haz clic en cualquier tarjeta para ver los detalles completos de cada evaluación."
        android:textSize="12sp"
        android:textColor="@color/text_secondary_dark"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp">

        <Button
            android:id="@+id/btnEliminarHistorial"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Eliminar todo"
            android:textSize="14sp"
            android:textColor="@color/text_primary_dark"
            android:padding="12dp"
            android:backgroundTint="@color/error_dark"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btnMenuPrincipal"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Menu Principal"
            android:textSize="14sp"
            android:textColor="@color/background_dark"
            android:padding="12dp"
            android:backgroundTint="@color/info_dark"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <ListView
        android:id="@+id/lvHistorial"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="8dp"
        android:divider="@color/surface_light"
        android:dividerHeight="1dp"
        android:background="@color/background_dark"/>

    <TextView
        android:id="@+id/tvMensajeVacio"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="No hay encuestas guardadas\n\nCompleta tu primera encuesta para ver el historial"
        android:textSize="16sp"
        android:textColor="@color/text_secondary_dark"
        android:textAlignment="center"
        android:gravity="center"
        android:visibility="gone"/>

</LinearLayout>